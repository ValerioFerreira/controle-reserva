// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  cpf       String   @unique
  nome      String
  senhaHash String
  perfil    String   @default("operador")
  createdAt DateTime @default(now())
  logs      Log[]
}

model Militar {
  id                  Int           @id @default(autoincrement())
  matricula           String        @unique
  postoGrad           String
  nome                String
  ordemHierarquica    Int
  sexo                String
  dataIngresso        DateTime
  dataUltimaPromocao  DateTime
  dataNascimento      DateTime
  reservaRequerimento DateTime?
  reservaCompulsoria  DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  averbacoes          Averbacao[]
  afastamentos        Afastamento[]
  logs                Log[]
}

model Averbacao {
  id                 Int      @id @default(autoincrement())
  militarId          Int
  tipo               String
  dias               Int
  processoSeiMilitar String?
  processoSeiInss    String?
  obs                String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  militar            Militar  @relation(fields: [militarId], references: [id])
}

model Afastamento {
  id                 Int      @id @default(autoincrement())
  militarId          Int
  tipo               String
  dias               Int
  processoSeiMilitar String?
  obs                String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  militar            Militar  @relation(fields: [militarId], references: [id])
}

model Log {
  id          Int      @id @default(autoincrement())
  usuarioId   Int?
  acao        String
  entidade    String
  entidadeId  String
  militarId   Int?
  payloadJson Json
  createdAt   DateTime @default(now())
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])
  militar     Militar? @relation(fields: [militarId], references: [id])
}
